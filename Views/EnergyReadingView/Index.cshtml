@*@{
    ViewData["Title"] = "Live Readings";
}

<div class="live-page">
    <div class="row g-4">
        <!-- Reading ID -->
        <div class="col-lg-4 col-md-6">
            <div class="live-card">
                <div class="live-card-top">
                    <span class="live-title">Reading ID</span>
                    <span class="live-icon">#️⃣</span>
                </div>
                <div class="live-value" id="readingIdVal">--</div>
                <div class="live-sub">Live</div>
            </div>
        </div>

        <!-- Device ID -->
        <div class="col-lg-4 col-md-6">
            <div class="live-card">
                <div class="live-card-top">
                    <span class="live-title">Device ID</span>
                    <span class="live-icon">💡</span>
                </div>
                <div class="live-value" id="deviceIdVal">--</div>
                <div class="live-sub">Live</div>
            </div>
        </div>

        <!-- Voltage -->
        <div class="col-lg-4 col-md-6">
            <div class="live-card">
                <div class="live-card-top">
                    <span class="live-title">Voltage</span>
                    <span class="live-icon">⚡</span>
                </div>
                <div class="live-value" id="voltageVal">--</div>
                <div class="live-sub">Live</div>
            </div>
        </div>

        <!-- Current -->
        <div class="col-lg-4 col-md-6">
            <div class="live-card">
                <div class="live-card-top">
                    <span class="live-title">Current</span>
                    <span class="live-icon">↻</span>
                </div>
                <div class="live-value" id="currentVal">--</div>
                <div class="live-sub">Live</div>
            </div>
        </div>

        <!-- Power -->
        <div class="col-lg-4 col-md-6">
            <div class="live-card">
                <div class="live-card-top">
                    <span class="live-title">Power</span>
                    <span class="live-icon">📶</span>
                </div>
                <div class="live-value" id="powerVal">--</div>
                <div class="live-sub">Live</div>
            </div>
        </div>
    </div>

    <div class="mt-3 text-muted small">
        Last update: <span id="lastTime">—</span>
    </div>
</div>

@section Scripts {
    <script>
        //AJAX endpoint , AJAX is used for live data display from Db (AJAX used as a frontend api which will only fetch data from Db)
        const endpoint = '@Url.Action("Latest", "EnergyReadingView")';

        function fmt(val, unit, decimals) {
            if (val === null || val === undefined) return '--';
            return Number(val).toFixed(decimals) + ' ' + unit;
        }

        async function refresh() {
            try {
                const res = await fetch(endpoint, { cache: 'no-store' });
                if (!res.ok) return;

                const d = await res.json();
                if (!d.hasData) {
                    document.getElementById('lastTime').innerText = 'No data yet';
                    return;
                }

                document.getElementById('readingIdVal').innerText = d.readingId ?? '--';
                document.getElementById('deviceIdVal').innerText  = d.deviceId ?? '--';
                document.getElementById('voltageVal').innerText   = fmt(d.voltage, 'V', 1);
                document.getElementById('currentVal').innerText   = fmt(d.current, 'A', 1);
                document.getElementById('powerVal').innerText     = fmt(d.power, 'kW', 2);

                document.getElementById('lastTime').innerText = new Date(d.timestamp).toLocaleString();
            } catch (e) {
                console.warn(e);
            }
        }

        refresh();
        setInterval(refresh, 3000); // refresh every 3s
    </script>
}
<style>
    .live-page {
    background: #d7f8f8;
    padding: 0.5rem 0 2rem 0;
}
.live-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 18px;
    padding: 22px;
    box-shadow: 0 2px 10px rgba(0,0,0,.04);
    height: 100%;
}
.live-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: .35rem;
}
.live-title {
    color: #7b6d66;
    font-weight: 600;
}
.live-icon {
    color: #f1ae55;
    font-size: 1.2rem;
}
.live-value {
    font-size: 2rem;
    font-weight: 800;
    color: #3b2e2a;
}
.live-sub {
    color: #a08f86;
    font-size: .9rem;
}

</style>*@


