@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const chartEndpoint = '@Url.Action("GetChartData", "Home")';

    const ctx = document.getElementById('voltageChart').getContext('2d');
    const chart = new Chart(ctx, {
        type: 'line',
        data: { labels: [], datasets: [] },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    suggestedMin: 180,
                    suggestedMax: 250,
                    title: { display: true, text: 'Voltage (V)' }
                }
            },
            plugins: {
                legend: { position: 'bottom' }
            },
            elements: { line: { tension: 0.25 } }
        }
    });

    async function refreshChart() {
        try {
            const res = await fetch(chartEndpoint, { cache: 'no-store' });
            if (!res.ok) return;
            const payload = await res.json();
            if (!payload.hasData) return;

            chart.data.labels = payload.labels;
            chart.data.datasets = [];

            payload.series.forEach((s, i) => {
                chart.data.datasets.push({
                    label: s.device || `Device ${s.deviceId}`,
                    data: s.values,
                    borderColor: ['#ff6384', '#4bc04b', '#5096ff'][i % 3],
                    pointRadius: 0,
                    fill: false
                });
            });

            payload.thresholds.forEach(v => {
                chart.data.datasets.push({
                    label: `TH: ${v} V`,
                    data: Array(payload.labels.length).fill(v),
                    borderColor: 'orange',
                    borderDash: [6, 6],
                    pointRadius: 0,
                    fill: false,
                    tension: 0
                });
            });

            chart.update('none');
        } catch (e) {
            console.error('Chart fetch failed', e);
        }
    }

    refreshChart();
    setInterval(refreshChart, 3000);
</script>


