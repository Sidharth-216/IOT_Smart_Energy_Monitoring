


@{
    ViewBag.Title = "Dashboard";
}
 <div class="mb-4 page-header">
        <h2 class="fw-bold text-gradient">⚡ IOT Based Smart Energy Monitoring System</h2>
        <p class="header-subtitle">Track Your Energy consumption effortlessly.</p>
    </div>
<div class="live-page">
    <div class="row g-4">
       
        <!-- Voltage -->
        <div class="col-lg-4 col-md-6">
            <div class="live-card voltage-card">
                <div class="live-card-top">
                    <span class="live-title">Voltage</span>
                    <span class="live-icon electric-pulse">⚡</span>
                </div>
                <div class="live-value" id="voltageVal">--</div>
                <div class="live-sub">
                    <span class="live-indicator"></span>
                    Live
                </div>
            </div>
        </div>

        <!-- Current -->
        <div class="col-lg-4 col-md-6">
            <div class="live-card current-card">
                <div class="live-card-top">
                    <span class="live-title">Current</span>
                    <span class="live-icon electric-pulse">↻</span>
                </div>
                <div class="live-value" id="currentVal">--</div>
                <div class="live-sub">
                    <span class="live-indicator"></span>
                    Live
                </div>
            </div>
        </div>

        <!-- Power -->
        <div class="col-lg-4 col-md-6">
            <div class="live-card power-card">
                <div class="live-card-top">
                    <span class="live-title">Power</span>
                    <span class="live-icon electric-pulse">📶</span>
                </div>
                <div class="live-value" id="powerVal">--</div>
                <div class="live-sub">
                    <span class="live-indicator"></span>
                    Live
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 text-muted small last-update">
        ⏱️ Last update: <span id="lastTime">—</span>
    </div>
      
        
    <div class="mt-4">
    <div class="chart-card">
        <h4 class="chart-title">📊 Voltage Trend</h4>
        <canvas id="voltageChart"></canvas>
    </div>
</div>
</div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

   <script>
    const chartEndpoint = '@Url.Action("GetChartData", "Home")';

    const ctx = document.getElementById('voltageChart').getContext('2d');
    const chart = new Chart(ctx, {
        type: 'bar', // 🔹 Changed from 'line' to 'bar'
        data: { labels: [], datasets: [] },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    suggestedMin: 180,
                    suggestedMax: 250,
                    title: { 
                        display: true, 
                        text: 'Voltage (V)',
                        color: '#00d4ff',
                        font: {
                            size: 14,
                            weight: 'bold',
                            family: "'Orbitron', sans-serif"
                        }
                    },
                    ticks: {
                        color: '#7dd3fc'
                    },
                    grid: {
                        color: 'rgba(0, 247, 255, 0.1)'
                    }
                },
                x: {
                    title: { 
                        display: true, 
                        text: 'Time',
                        color: '#00d4ff',
                        font: {
                            size: 14,
                            weight: 'bold',
                            family: "'Orbitron', sans-serif"
                        }
                    },
                    ticks: {
                        color: '#7dd3fc'
                    },
                    grid: {
                        color: 'rgba(0, 247, 255, 0.1)'
                    }
                }
            },
            plugins: {
                legend: { 
                    position: 'bottom',
                    labels: {
                        color: '#7dd3fc',
                        font: {
                            family: "'Inter', sans-serif",
                            size: 12
                        }
                    }
                }
            }
        }
    });

    async function refreshChart() {
        try {
            const res = await fetch(chartEndpoint, { cache: 'no-store' });
            if (!res.ok) return;
            const payload = await res.json();
            if (!payload.hasData) return;

            chart.data.labels = payload.labels;
            chart.data.datasets = [];
            const greenShades = ['#2ecc71', '#27ae60', '#1abc9c'];
            payload.series.forEach((s, i) => {
                chart.data.datasets.push({
                    label: s.device || `Device ${s.deviceId}`,
                    data: s.values,
                    backgroundColor:greenShades[i % greenShades.length], // 🔹 for bars
                    borderWidth: 1,
                    barPercentage: 0.5,      // 🔹 decrease bar thickness (0.5 = 50%)
                    categoryPercentage: 0.8 // 🔹 space between groups
                });
            });
        
            payload.thresholds.forEach(v => {
                chart.data.datasets.push({
                    label: `TH: ${v} V`,
                    data: Array(payload.labels.length).fill(v),
                    type: 'line', // 🔹 Keep thresholds as lines
                    borderColor: 'green',
                    borderDash: [6, 6],
                    pointRadius: 0,
                    fill: false
                });
            });

            chart.update('none');
        } catch (e) {
            console.error('Chart fetch failed', e);
        }
    }

    refreshChart();
    setInterval(refreshChart, 3000);
</script>


    <script>
        //AJAX endpoint , AJAX is used for live data display from Db (AJAX used as a frontend api which will only fetch data from Db)
        const endpoint = '@Url.Action("Latest", "EnergyReadingView")';

        function fmt(val, unit, decimals) {
            if (val === null || val === undefined) return '--';
            return Number(val).toFixed(decimals) + ' ' + unit;
        }

        async function refresh() {
            try {
                const res = await fetch(endpoint, { cache: 'no-store' });
                if (!res.ok) return;

                const d = await res.json();
                if (!d.hasData) {
                    document.getElementById('lastTime').innerText = 'No data yet';
                    return;
                }

               // document.getElementById('readingIdVal').innerText = d.readingId ?? '--';
                //document.getElementById('deviceIdVal').innerText  = d.deviceId ?? '--';
                document.getElementById('voltageVal').innerText   = fmt(d.voltage, 'V', 1);
                document.getElementById('currentVal').innerText   = fmt(d.current, 'A', 1);
                document.getElementById('powerVal').innerText     = fmt(d.power, 'kW', 2);

                document.getElementById('lastTime').innerText = new Date(d.timestamp).toLocaleString();
            } catch (e) {
                console.warn(e);
            }
        }

        refresh();
        setInterval(refresh, 3000); // refresh every 3s
    </script>
    
    
}
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@400;600;700&display=swap');

    * {
        box-sizing: border-box;
    }

    /* Page Background with Electric Theme */
    .live-page {
        background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
        padding: 2rem 0;
        position: relative;
        overflow: hidden;
    }

    .live-page::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
            radial-gradient(circle at 20% 50%, rgba(0, 247, 255, 0.1) 0%, transparent 50%),
            radial-gradient(circle at 80% 80%, rgba(255, 215, 0, 0.1) 0%, transparent 50%);
        pointer-events: none;
    }

    /* Header Styling */
    .page-header {
        text-align: center;
        padding: 1.5rem 0;
        background: linear-gradient(135deg, rgba(15, 32, 39, 0.9) 0%, rgba(44, 83, 100, 0.9) 100%);
        border-radius: 20px;
        margin-bottom: 2rem;
        box-shadow: 0 8px 32px rgba(0, 247, 255, 0.2);
        border: 1px solid rgba(0, 247, 255, 0.3);
    }

    .text-gradient {
        background: linear-gradient(45deg, #00f7ff, #ffd700, #00f7ff);
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradient-shift 3s ease infinite;
        font-family: 'Orbitron', sans-serif;
        letter-spacing: 2px;
    }

    @@keyframes gradient-shift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }

    .header-subtitle {
        color: #a0d8e0;
        font-size: 1.1rem;
        margin-top: 0.5rem;
        font-family: 'Inter', sans-serif;
    }

    /* Live Cards with Electric Theme */
    .live-card {
        background: linear-gradient(145deg, rgba(20, 40, 60, 0.95) 0%, rgba(30, 50, 70, 0.95) 100%);
        border: 2px solid rgba(0, 247, 255, 0.3);
        border-radius: 20px;
        padding: 28px;
        box-shadow: 
            0 8px 32px rgba(0, 0, 0, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        height: 100%;
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .live-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(0, 247, 255, 0.1) 0%, transparent 70%);
        animation: rotate-gradient 8s linear infinite;
        pointer-events: none;
    }

    @@keyframes rotate-gradient {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .live-card:hover {
        transform: translateY(-8px) scale(1.02);
        border-color: rgba(0, 247, 255, 0.6);
        box-shadow: 
            0 16px 48px rgba(0, 247, 255, 0.3),
            inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    /* Voltage Card - Blue Electric */
    .voltage-card {
        border-color: rgba(0, 157, 255, 0.5);
    }
    .voltage-card:hover {
        border-color: rgba(0, 157, 255, 0.8);
        box-shadow: 0 16px 48px rgba(0, 157, 255, 0.4);
    }

    /* Current Card - Cyan Electric */
    .current-card {
        border-color: rgba(0, 247, 255, 0.5);
    }
    .current-card:hover {
        border-color: rgba(0, 247, 255, 0.8);
        box-shadow: 0 16px 48px rgba(0, 247, 255, 0.4);
    }

    /* Power Card - Gold Electric */
    .power-card {
        border-color: rgba(255, 215, 0, 0.5);
    }
    .power-card:hover {
        border-color: rgba(255, 215, 0, 0.8);
        box-shadow: 0 16px 48px rgba(255, 215, 0, 0.4);
    }

    .live-card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
    }

    .live-title {
        color: #00d4ff;
        font-weight: 700;
        font-size: 1rem;
        font-family: 'Orbitron', sans-serif;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
    }

    .live-icon {
        font-size: 1.8rem;
        filter: drop-shadow(0 0 8px currentColor);
    }

    .electric-pulse {
        animation: electric-pulse 2s ease-in-out infinite;
    }

    @@keyframes electric-pulse {
        0%, 100% { 
            transform: scale(1);
            filter: drop-shadow(0 0 8px rgba(255, 215, 0, 0.8));
        }
        50% { 
            transform: scale(1.2);
            filter: drop-shadow(0 0 15px rgba(255, 215, 0, 1));
        }
    }

    .live-value {
        font-size: 2.5rem;
        font-weight: 900;
        color: #ffffff;
        font-family: 'Orbitron', sans-serif;
        text-shadow: 
            0 0 10px rgba(0, 247, 255, 0.8),
            0 0 20px rgba(0, 247, 255, 0.4);
        letter-spacing: 2px;
        position: relative;
        z-index: 1;
    }

    .live-sub {
        color: #7dd3fc;
        font-size: 0.95rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative;
        z-index: 1;
        font-family: 'Inter', sans-serif;
    }

    .live-indicator {
        width: 8px;
        height: 8px;
        background: #00ff88;
        border-radius: 50%;
        animation: pulse-dot 1.5s ease-in-out infinite;
        box-shadow: 0 0 10px #00ff88;
    }

    @@keyframes pulse-dot {
        0%, 100% { 
            opacity: 1;
            transform: scale(1);
        }
        50% { 
            opacity: 0.5;
            transform: scale(1.3);
        }
    }

    .last-update {
        text-align: center;
        color: #7dd3fc;
        font-weight: 600;
        text-shadow: 0 0 5px rgba(125, 211, 252, 0.5);
        font-family: 'Inter', sans-serif;
    }

    /* Chart Card Styling */
    .chart-card {
        background: linear-gradient(145deg, rgba(20, 40, 60, 0.95) 0%, rgba(30, 50, 70, 0.95) 100%);
        border: 2px solid rgba(0, 247, 255, 0.3);
        border-radius: 20px;
        padding: 25px;
        box-shadow: 
            0 8px 32px rgba(0, 0, 0, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        height: 450px;
        position: relative;
        overflow: hidden;
    }

    .chart-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(0, 247, 255, 0.08) 0%, transparent 70%);
        animation: rotate-gradient 10s linear infinite;
        pointer-events: none;
    }

    .chart-title {
        color: #00d4ff;
        font-family: 'Orbitron', sans-serif;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 15px;
        text-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
        position: relative;
        z-index: 1;
    }

    #voltageChart { 
        width: 100%; 
        height: calc(100% - 50px);
        position: relative;
        z-index: 1;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .live-value {
            font-size: 2rem;
        }

        .live-card {
            padding: 20px;
        }

        .chart-card {
            height: 350px;
        }

        .text-gradient {
            font-size: 1.5rem;
        }
    }
</style>