<!--views/Energy/live.cshtml-->
@{
    ViewBag.Title = "Live Energy Reading";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap');

    body {
        background: #0a0e27;
        font-family: 'Orbitron', 'Segoe UI', sans-serif;
        color: #fff;
        overflow-x: hidden;
    }

    .energy-dashboard {
        max-width: 1400px;
        margin: 0 auto;
        padding: 30px 20px;
        position: relative;
    }

    /* Animated Background */
    .energy-dashboard::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: 
            radial-gradient(circle at 20% 50%, rgba(0, 255, 255, 0.1) 0%, transparent 50%),
            radial-gradient(circle at 80% 80%, rgba(138, 43, 226, 0.1) 0%, transparent 50%),
            radial-gradient(circle at 40% 20%, rgba(255, 0, 255, 0.05) 0%, transparent 50%);
        z-index: -1;
        animation: pulse 8s ease-in-out infinite;
    }

   @@keyframes pulse {
        0%, 100% { opacity: 0.6; }
        50% { opacity: 1; }
    }

    /* Header */
    .dashboard-header {
        text-align: center;
        margin-bottom: 50px;
        position: relative;
    }

    .dashboard-title {
        font-size: 3.5rem;
        font-weight: 900;
        background: linear-gradient(45deg, #00ffff, #ff00ff, #00ffff);
        background-size: 200% 200%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: gradientShift 3s ease infinite;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin: 0;
    }

    @@keyframes gradientShift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }

    .status-badge {
        display: inline-block;
        margin-top: 15px;
        padding: 8px 20px;
        background: rgba(0, 255, 255, 0.1);
        border: 2px solid #00ffff;
        border-radius: 30px;
        font-size: 0.9rem;
        color: #00ffff;
        animation: borderGlow 2s ease-in-out infinite;
    }

    @@keyframes borderGlow {
        0%, 100% { box-shadow: 0 0 10px rgba(0, 255, 255, 0.5); }
        50% { box-shadow: 0 0 25px rgba(0, 255, 255, 0.8); }
    }

    /* Metrics Grid */
    .metrics-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
        margin-bottom: 40px;
    }

    .metric-box {
        background: linear-gradient(135deg, rgba(26, 26, 46, 0.9) 0%, rgba(30, 30, 60, 0.9) 100%);
        border: 2px solid transparent;
        border-radius: 20px;
        padding: 30px;
        position: relative;
        overflow: hidden;
        transition: all 0.4s ease;
    }

    .metric-box::before {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        right: -2px;
        bottom: -2px;
        background: linear-gradient(45deg, #00ffff, #ff00ff, #00ff00, #00ffff);
        background-size: 400% 400%;
        border-radius: 20px;
        z-index: -1;
        opacity: 0;
        transition: opacity 0.4s ease;
        animation: borderRotate 4s linear infinite;
    }

    @@keyframes borderRotate {
        0% { background-position: 0% 50%; }
        100% { background-position: 400% 50%; }
    }

    .metric-box:hover::before {
        opacity: 1;
    }

    .metric-box:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 20px 60px rgba(0, 255, 255, 0.3);
    }

    .metric-icon-wrapper {
        font-size: 3rem;
        margin-bottom: 15px;
        display: inline-block;
        animation: float 3s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
    }

    .metric-label {
        color: #f2f2f5ff;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 10px;
        font-weight: 700;
    }

    .metric-reading {
        font-size: 2.8rem;
        font-weight: 900;
        background: linear-gradient(90deg, #00ffff, #00d4ff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
        margin-bottom: 5px;
    }

    .metric-unit {
        font-size: 1.1rem;
        color: #5dd9e8;
        font-weight: 400;
    }

    /* Chart Section */
    .chart-container {
        background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(30, 30, 60, 0.95) 100%);
        border: 2px solid rgba(0, 255, 255, 0.3);
        border-radius: 25px;
        padding: 35px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
    }

    .chart-container::after {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.1), transparent);
        animation: shimmer 3s infinite;
    }

    @@keyframes shimmer {
        0% { left: -100%; }
        100% { left: 100%; }
    }

    .chart-header {
        display: flex;
        align-items: center;
        margin-bottom: 25px;
        gap: 15px;
    }

    .chart-title {
        font-size: 1.6rem;
        font-weight: 900;
        color: #00ffff;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .chart-icon {
        font-size: 2rem;
        animation: rotate 4s linear infinite;
    }

    @@keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* Insights Panel */
    .insights-panel {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 25px;
        margin-bottom: 40px;
    }

    .insight-card {
        background: linear-gradient(135deg, rgba(138, 43, 226, 0.2) 0%, rgba(0, 255, 255, 0.2) 100%);
        border: 2px solid rgba(138, 43, 226, 0.5);
        border-radius: 20px;
        padding: 25px;
        position: relative;
        overflow: hidden;
    }

    .insight-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
        animation: rotate 10s linear infinite;
    }

    .insight-title {
        font-size: 0.9rem;
        color: #0b0b0bff;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
        font-weight: 700;
    }

    .insight-value {
        font-size: 1.8rem;
        font-weight: 900;
        color: #ff00ff;
        text-shadow: 0 0 20px rgba(255, 0, 255, 0.6);
    }

    /* Chat Section */
    .chat-container {
        background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(30, 30, 60, 0.95) 100%);
        border: 2px solid rgba(0, 255, 255, 0.3);
        border-radius: 25px;
        overflow: hidden;
        box-shadow: 0 10px 50px rgba(0, 0, 0, 0.5);
    }

    .chat-header {
        background: linear-gradient(90deg, rgba(0, 255, 255, 0.2), rgba(138, 43, 226, 0.2));
        padding: 25px;
        display: flex;
        align-items: center;
        gap: 15px;
        border-bottom: 2px solid rgba(0, 255, 255, 0.3);
    }

    .chat-header-icon {
        font-size: 2rem;
        animation: bounce 2s ease-in-out infinite;
    }

    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }

    .chat-header-title {
        font-size: 1.4rem;
        font-weight: 900;
        color: #00ffff;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .chat-messages {
        height: 400px;
        overflow-y: auto;
        padding: 25px;
        background: rgba(10, 14, 39, 0.5);
    }

    .chat-messages::-webkit-scrollbar {
        width: 8px;
    }

    .chat-messages::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.2);
    }

    .chat-messages::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, #00ffff, #8a2be2);
        border-radius: 10px;
    }

    .message {
        margin-bottom: 20px;
        padding: 15px 20px;
        border-radius: 15px;
        max-width: 80%;
        animation: messageSlide 0.4s ease;
        position: relative;
    }

    @@keyframes messageSlide {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .message.you {
        background: linear-gradient(135deg, rgba(0, 255, 255, 0.3), rgba(0, 200, 255, 0.3));
        border: 1px solid rgba(0, 255, 255, 0.5);
        margin-left: auto;
        text-align: right;
        box-shadow: 0 5px 20px rgba(0, 255, 255, 0.3);
    }

    .message.ai {
        background: linear-gradient(135deg, rgba(138, 43, 226, 0.3), rgba(186, 85, 211, 0.3));
        border: 1px solid rgba(138, 43, 226, 0.5);
        margin-right: auto;
        box-shadow: 0 5px 20px rgba(138, 43, 226, 0.3);
    }

    .message.error {
        background: linear-gradient(135deg, rgba(255, 0, 100, 0.3), rgba(255, 50, 50, 0.3));
        border: 1px solid rgba(255, 0, 100, 0.5);
    }

    .message b {
        color: #00ffff;
        font-weight: 900;
    }

    .chat-input-area {
        padding: 25px;
        background: rgba(15, 20, 45, 0.9);
        border-top: 2px solid rgba(0, 255, 255, 0.3);
        display: flex;
        gap: 15px;
    }

    .chat-input-field {
        flex: 1;
        background: rgba(0, 0, 0, 0.5);
        border: 2px solid rgba(0, 255, 255, 0.4);
        border-radius: 30px;
        padding: 15px 25px;
        color: #fff;
        font-size: 1rem;
        font-family: 'Orbitron', sans-serif;
        transition: all 0.3s ease;
    }

    .chat-input-field::placeholder {
        color: rgba(255, 255, 255, 0.4);
    }

    .chat-input-field:focus {
        outline: none;
        border-color: #00ffff;
        box-shadow: 0 0 30px rgba(0, 255, 255, 0.4);
        background: rgba(0, 0, 0, 0.7);
    }

    .chat-send-btn {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        border: none;
        background: linear-gradient(135deg, #00ffff, #8a2be2);
        color: #fff;
        font-size: 1.5rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .chat-send-btn::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }

    .chat-send-btn:hover::before {
        width: 300px;
        height: 300px;
    }

    .chat-send-btn:hover {
        transform: scale(1.1) rotate(15deg);
        box-shadow: 0 0 40px rgba(0, 255, 255, 0.6);
    }

    .chat-send-btn i {
        position: relative;
        z-index: 1;
    }

    @@media (max-width: 768px) {
        .dashboard-title {
            font-size: 2rem;
        }
        
        .insights-panel {
            grid-template-columns: 1fr;
        }
        
        .metrics-container {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="energy-dashboard">
    <div class="dashboard-header">
        <h1 class="dashboard-title">⚡ WATTWISE ⚡</h1>
        <div class="status-badge">● LIVE MONITORING</div>
    </div>

    <div class="metrics-container">
        <div class="metric-box">
            <div class="metric-icon-wrapper">⚡</div>
            <div class="metric-label">Voltage</div>
            <div class="metric-reading">
                <span id="voltage">--</span>
                <span class="metric-unit">V</span>
            </div>
        </div>

        <div class="metric-box">
            <div class="metric-icon-wrapper">🔋</div>
            <div class="metric-label">Current</div>
            <div class="metric-reading">
                <span id="current">--</span>
                <span class="metric-unit">A</span>
            </div>
        </div>

        <div class="metric-box">
            <div class="metric-icon-wrapper">💡</div>
            <div class="metric-label">Power</div>
            <div class="metric-reading">
                <span id="power">--</span>
                <span class="metric-unit">W</span>
            </div>
        </div>

        <div class="metric-box">
            <div class="metric-icon-wrapper">⏱️</div>
            <div class="metric-label">Timestamp</div>
            <div class="metric-reading" style="font-size: 1.4rem;">
                <span id="timestamp">--</span>
            </div>
        </div>
    </div>

    <div class="chart-container">
        <div class="chart-header">
            <div class="chart-icon">📊</div>
            <h3 class="chart-title">Power Flow Analysis</h3>
        </div>
        <canvas id="liveChart" height="100"></canvas>
    </div>

    <div class="insights-panel">
        <div class="insight-card">
            <div class="insight-title">⚡ Consumption Level</div>
            <div class="insight-value" id="consumptionLevel">--</div>
        </div>

        <div class="insight-card">
            <div class="insight-title">💡 Smart Energy Tip</div>
            <div class="insight-value" style="font-size: 1.2rem;" id="consumptionTip">--</div>
        </div>
    </div>

    <div class="chat-container">
        <div class="chat-header">
            <div class="chat-header-icon">🤖</div>
            <div class="chat-header-title">AI Assistant</div>
        </div>
        <div id="chatBox" class="chat-messages"></div>
        <div class="chat-input-area">
            <input type="text" id="userMessage" class="chat-input-field" placeholder="Ask me anything about your energy..." />
            <button id="sendBtn" class="chat-send-btn">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // Connect to your streaming API
    const evtSource = new EventSource("/api/firebasestream/stream");

    // === Analysis Trigger Logic ===
    let lastReadings = [];
    const MAX_BUFFER = 6;
    const STABLE_THRESHOLD = 0.03;
    const MEANINGFUL_JUMP = 0.05;

    evtSource.onmessage = async function (event) {
        console.log("Received: ", event.data);

        try {
            const reading = JSON.parse(event.data);

            document.getElementById("voltage").innerText = reading.voltage;
            document.getElementById("current").innerText = reading.current;
            document.getElementById("power").innerText = reading.power;
            document.getElementById("timestamp").innerText = reading.timestamp;

            updateChart(reading.power);

            lastReadings.push(reading.power);
            if (lastReadings.length > MAX_BUFFER) {
                lastReadings.shift();
            }

            maybeAnalyze(reading);

        } catch (err) {
            console.log("Invalid JSON:", err);
        }
    };

    evtSource.onerror = function (event) {
        console.log("Stream Error:", event);
    };

    // Chart Configuration
    const ctx = document.getElementById("liveChart").getContext("2d");

    const liveChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: [],
            datasets: [{
                label: "Power (W)",
                data: [],
                borderColor: '#00ffff',
                backgroundColor: 'rgba(0, 255, 255, 0.1)',
                borderWidth: 3,
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#00ffff',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6
            }]
        },
        options: {
            responsive: true,
            animation: { duration: 0 },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(0, 255, 255, 0.1)'
                    },
                    ticks: {
                        color: '#00ffff',
                        font: {
                            family: 'Orbitron',
                            weight: 'bold'
                        }
                    }
                },
                x: {
                    grid: {
                        color: 'rgba(0, 255, 255, 0.1)'
                    },
                    ticks: {
                        color: '#8a2be2',
                        font: {
                            family: 'Orbitron'
                        }
                    }
                }
            },
            plugins: {
                legend: {
                    labels: {
                        color: '#00ffff',
                        font: {
                            family: 'Orbitron',
                            size: 14,
                            weight: 'bold'
                        }
                    }
                }
            }
        }
    });

    function updateChart(power) {
        const t = new Date().toLocaleTimeString();

        liveChart.data.labels.push(t);
        liveChart.data.datasets[0].data.push(power);

        if (liveChart.data.labels.length > 15) {
            liveChart.data.labels.shift();
            liveChart.data.datasets[0].data.shift();
        }

        liveChart.update();
    }

    async function maybeAnalyze(latest) {
        if (lastReadings.length < MAX_BUFFER) return;

        const prevAvg = lastReadings.slice(0, -1).reduce((a, b) => a + b) / (lastReadings.length - 1);
        const diff = Math.abs((latest.power - prevAvg) / prevAvg);

        const recent = lastReadings.slice(-4);
        const stable = recent.every(v => Math.abs((v - latest.power) / latest.power) < STABLE_THRESHOLD);

        if (stable && diff < MEANINGFUL_JUMP) {
            console.log("Stable — skipping analysis.");
            return;
        }

        console.log("Triggering AI analysis...");
        await analyzeSuggestion(latest);
    }

    async function analyzeSuggestion(d) {
        const levelEl = document.getElementById('consumptionLevel');
        const tipEl = document.getElementById('consumptionTip');
        const ANALYZE_ENDPOINT = "/FirebaseStreamController/AnalyzeReadingAI";

        const parsedReading = {
            Voltage: Number(d.voltage ?? d.Voltage ?? 0),
            Current: Number(d.current ?? d.Current ?? 0),
            Power: Number(d.power ?? d.Power ?? 0)
        };

        if (parsedReading.Power <= 5) {
            if (levelEl) levelEl.innerText = 'Low';
            if (tipEl) tipEl.innerText = 'Consumption minimal — no action required.';
            return;
        }

        analyzeSuggestion._endpoint = ANALYZE_ENDPOINT;
        analyzeSuggestion._payload = parsedReading;
        if (levelEl) levelEl.innerText = 'Analyzing...';
        if (tipEl) {
            tipEl.innerText = 'Contacting analysis service...';
            tipEl.title = 'If you get Error 404, verify the server route /FirebaseStream/AnalyzeReadingAI exists and is reachable.';
        }

        const now = Date.now();
        const MIN_INTERVAL_MS = 3000;
        if (!analyzeSuggestion._lastRun) analyzeSuggestion._lastRun = 0;
        if (now - analyzeSuggestion._lastRun < MIN_INTERVAL_MS) {
            if (tipEl) tipEl.innerText = 'Queued — waiting to reduce requests';
            return;
        }
        analyzeSuggestion._lastRun = now;
        if (tipEl) tipEl.innerText = 'Analyzing...';

        try {
            const payload = {
                Voltage: Number(d.voltage ?? d.Voltage ?? 0),
                Current: Number(d.current ?? d.Current ?? 0),
                Power: Number(d.power ?? d.Power ?? 0)
            };

            const analysisRes = await fetch("/Llama/AnalyzeReadingAI", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });

            const raw = await analysisRes.text();

            if (!analysisRes.ok) {
                if (levelEl) levelEl.innerText = '—';
                if (tipEl) tipEl.innerText = raw || `Error ${analysisRes.status}`;
                return;
            }

            let analysis;
            try {
                analysis = JSON.parse(raw);
            } catch {
                if (levelEl) levelEl.innerText = '—';
                if (tipEl) tipEl.innerText = raw || 'No tip available';
                return;
            }

            const level = analysis.consumptionLevel ?? analysis.level ?? '—';
            const tip = analysis.tip ?? analysis.reply ?? analysis.message ?? 'No tip available';

            if (levelEl) levelEl.innerText = level;
            if (tipEl) tipEl.innerText = tip;

        } catch (err) {
            console.warn(err);
            if (levelEl) levelEl.innerText = 'Unavailable';
            if (tipEl) tipEl.innerText = 'Could not fetch analysis';
        }
    }

    // Chat Section
    const chatBox = document.getElementById("chatBox");
    const userMessage = document.getElementById("userMessage");
    const sendBtn = document.getElementById("sendBtn");

    sendBtn.addEventListener("click", sendMessage);
    userMessage.addEventListener("keypress", function(e) {
        if (e.key === "Enter") sendMessage();
    });

    function appendMessage(sender, message, isError = false) {
        const div = document.createElement("div");
        div.classList.add("message", sender.toLowerCase());
        if (isError) div.classList.add("error");
        div.innerHTML = `<b>${sender}:</b> ${message}`;
        chatBox.appendChild(div);
        chatBox.scrollTop = chatBox.scrollHeight;
    }

    function sendMessage() {
        const message = userMessage.value.trim();
        if (!message) return;

        appendMessage("You", message);
        userMessage.value = "";

        fetch("/Llama/Chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ Question: message })
        })
        .then(res => res.json())
        .then(data => appendMessage("AI", data.reply ?? JSON.stringify(data)))
        .catch(err => appendMessage("Error", err.message, true));
    }
</script>