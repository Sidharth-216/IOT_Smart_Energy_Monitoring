

@model List<SmartEnergy.Web.Models.HistoricalStatsModel>
@{
    ViewData["Title"] = "Historical Energy Stats";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: #0a0e27;
            min-height: 100vh;
            padding: 20px 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #fff;
        }
        .main-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 0 15px;
        }
        .stats-card {
            background: rgba(26, 26, 46, 0.95);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: 0 10px 30px rgba(0, 255, 255, 0.1);
            border: 1px solid rgba(0, 255, 255, 0.2);
            animation: slideUp 0.5s ease-out;
        }
        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .header-section {
            background: linear-gradient(135deg, rgba(0, 255, 255, 0.2), rgba(138, 43, 226, 0.2));
            backdrop-filter: blur(10px);
            border: 2px solid rgba(0, 255, 255, 0.3);
            color: white;
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0, 255, 255, 0.2);
            animation: slideUp 0.3s ease-out;
        }
        .header-section h1 {
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 10px;
            color: #2c9f9fff;
            text-shadow: 0 0 20px rgba(0, 212, 212, 0.5);
        }
        .header-section p {
            font-size: 1.1rem;
            opacity: 0.95;
            color: #090808ff;
        }
        .metric-card {
            background: linear-gradient(135deg, rgba(0, 255, 255, 0.15), rgba(138, 43, 226, 0.15));
            backdrop-filter: blur(10px);
            border: 2px solid rgba(0, 255, 255, 0.3);
            color: white;
            padding: 25px;
            border-radius: 12px;
            margin-bottom: 15px;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }
        .metric-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }
        .metric-card:hover::before {
            left: 100%;
        }
        .metric-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0, 255, 255, 0.3);
            border-color: rgba(0, 255, 255, 0.5);
        }
        .metric-value {
            font-size: 2.8rem;
            font-weight: bold;
            margin: 15px 0;
            color: #00d4d4;
            text-shadow: 0 0 20px rgba(0, 212, 212, 0.6);
        }
        .metric-label {
            font-size: 0.85rem;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
            color: #141313ff;
        }
        .metric-unit {
            font-size: 1rem;
            opacity: 0.85;
            font-weight: 500;
            color: #141313ff;
        }
        .chart-container {
            position: relative;
            height: 400px;
            margin-top: 20px;
            background: rgba(15, 15, 35, 0.5);
            border-radius: 12px;
            padding: 15px;
            border: 1px solid rgba(0, 255, 255, 0.1);
        }
        .filter-section {
            background: rgba(26, 26, 46, 0.95);
            border: 1px solid rgba(0, 255, 255, 0.2);
            padding: 25px;
            border-radius: 12px;
            margin-bottom: 20px;
            box-shadow: 0 5px 15px rgba(0, 255, 255, 0.1);
            animation: slideUp 0.4s ease-out;
        }
        .filter-section label {
            font-weight: 600;
            color: #e0e0e0;
            margin-bottom: 8px;
        }
        .btn-primary {
            background: linear-gradient(135deg, rgba(0, 212, 212, 0.3), rgba(138, 43, 226, 0.3));
            border: 2px solid rgba(0, 212, 212, 0.5);
            color: #00d4d4;
            padding: 12px 35px;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(0, 212, 212, 0.2);
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, rgba(0, 212, 212, 0.5), rgba(138, 43, 226, 0.5));
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0, 212, 212, 0.4);
            border-color: rgba(0, 212, 212, 0.7);
            color: #ffffff;
        }
        .loading-spinner {
            display: none;
            text-align: center;
            padding: 60px;
            animation: fadeIn 0.3s;
        }
       @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .spinner-border {
            width: 3.5rem;
            height: 3.5rem;
            color: #00d4d4;
            border-width: 4px;
        }
        .metric-icon {
            font-size: 2.5rem;
            margin-bottom: 15px;
            color: #00d4d4;
            text-shadow: 0 0 20px rgba(0, 212, 212, 0.6);
        }
        .date-range-info {
            background: linear-gradient(135deg, rgba(0, 212, 212, 0.1), rgba(138, 43, 226, 0.1));
            border: 1px solid rgba(0, 212, 212, 0.3);
            padding: 15px;
            border-radius: 10px;
            margin-top: 15px;
            border-left: 4px solid #00d4d4;
            font-weight: 500;
            color: #e0e0e0;
        }
        .section-title {
            font-size: 1.8rem;
            font-weight: bold;
            color: #00d4d4;
            text-shadow: 0 0 20px rgba(0, 212, 212, 0.5);
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid rgba(0, 212, 212, 0.3);
        }
        .section-title i {
            margin-right: 10px;
        }
        .table {
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 255, 255, 0.1);
        }
        .table thead {
            background: linear-gradient(135deg, rgba(0, 255, 255, 0.3), rgba(138, 43, 226, 0.3));
            color: white;
        }
        .table thead th {
            border: none;
            padding: 15px;
            font-weight: 600;
            color: #00d4d4;
        }
        .table tbody {
            background: rgba(15, 15, 35, 0.5);
        }
        .table tbody td {
            border-color: rgba(0, 255, 255, 0.1);
            color: #e0e0e0;
            padding: 12px 15px;
        }
        .table-hover tbody tr:hover {
            background: rgba(0, 255, 255, 0.1);
            transform: scale(1.01);
            transition: all 0.2s;
        }
        .badge {
            padding: 8px 12px;
            font-size: 0.9rem;
            font-weight: 600;
        }
        .form-control, .form-select {
            background: rgba(15, 15, 35, 0.8);
            border: 2px solid rgba(0, 255, 255, 0.2);
            color: #e0e0e0;
            border-radius: 8px;
            padding: 10px 15px;
            transition: all 0.3s;
        }
        .form-control:focus, .form-select:focus {
            background: rgba(15, 15, 35, 0.9);
            border-color: #00d4d4;
            color: #ffffff;
            box-shadow: 0 0 0 0.2rem rgba(0, 212, 212, 0.25);
        }
        .form-control::placeholder {
            color: #8b8ba7;
        }
        .form-select option {
            background: #1a1a2e;
            color: #e0e0e0;
        }
        .column-section {
            background: rgba(26, 26, 46, 0.95);
            border: 1px solid rgba(0, 255, 255, 0.2);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            transition: all 0.3s ease;
        }
        .column-section:hover {
            border-color: rgba(0, 255, 255, 0.4);
            box-shadow: 0 5px 20px rgba(0, 255, 255, 0.15);
        }
        @@media (max-width: 768px) {
            .header-section h1 {
                font-size: 1.8rem;
            }
            .metric-value {
                font-size: 2rem;
            }
            .chart-container {
                height: 300px;
            }
        }
    </style>
</head>
<body>
    <div class="main-container">
        <div class="header-section">
            <h1><i class="fas fa-chart-line"></i> Historical Energy Statistics</h1>
            <p class="mb-0"><i class="fas fa-bolt"></i> Analyze your energy consumption patterns over time</p>
        </div>

        <div class="filter-section">
            <div class="row align-items-end">
                <div class="col-md-3 mb-3 mb-md-0">
                    <label class="form-label"><i class="fas fa-calendar-alt"></i> Start Date</label>
                    <input type="date" id="startDate" class="form-control" />
                </div>
                <div class="col-md-3 mb-3 mb-md-0">
                    <label class="form-label"><i class="fas fa-calendar-check"></i> End Date</label>
                    <input type="date" id="endDate" class="form-control" />
                </div>
                <div class="col-md-3 mb-3 mb-md-0">
                    <label class="form-label"><i class="fas fa-sliders-h"></i> Primary Metric</label>
                    <select id="metricSelect" class="form-select">
                        <option value="power">Power (W)</option>
                        <option value="current">Current (A)</option>
                        <option value="voltage">Voltage (V)</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button id="loadDataBtn" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Load Data
                    </button>
                </div>
            </div>
            <div class="date-range-info" id="dateRangeInfo" style="display:none;">
                <i class="fas fa-info-circle"></i> Showing data from <strong id="dateRangeText"></strong>
            </div>
        </div>

        <div class="loading-spinner" id="loadingSpinner">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 fw-bold" style="font-size: 1.2rem; color: #00d4d4;">Loading historical data...</p>
        </div>

        <div id="statsContainer" style="display:none;">
            <!-- Summary Cards -->
            <div class="row" id="summaryCards">
                <!-- Summary cards will be inserted here -->
            </div>

            <!-- Column-wise Sections -->
            <div class="row">
                <!-- Power Consumption Column -->
                <div class="col-lg-6 mb-4">
                    <div class="column-section">
                        <h3 class="section-title">
                            <i class="fas fa-bolt"></i> Power Consumption
                        </h3>
                        <div class="chart-container">
                            <canvas id="powerCanvas"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Current Column -->
                <div class="col-lg-6 mb-4">
                    <div class="column-section">
                        <h3 class="section-title">
                            <i class="fas fa-wave-square"></i> Current
                        </h3>
                        <div class="chart-container">
                            <canvas id="currentCanvas"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Voltage Column -->
                <div class="col-lg-6 mb-4">
                    <div class="column-section">
                        <h3 class="section-title">
                            <i class="fas fa-plug"></i> Voltage
                        </h3>
                        <div class="chart-container">
                            <canvas id="voltageCanvas"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Energy Consumed Column -->
                <div class="col-lg-6 mb-4">
                    <div class="column-section">
                        <h3 class="section-title">
                            <i class="fas fa-battery-three-quarters"></i> Energy Consumed
                        </h3>
                        <div class="chart-container">
                            <canvas id="energyCanvas"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detailed Table -->
            <div class="stats-card">
                <h3 class="section-title">
                    <i class="fas fa-table"></i> Detailed Daily Breakdown
                </h3>
                <div class="table-responsive mt-3">
                    <table class="table table-striped table-hover" id="detailsTable">
                        <thead>
                            <tr>
                                <th><i class="fas fa-calendar-day"></i> Date</th>
                                <th><i class="fas fa-bolt"></i> Avg Power (W)</th>
                                <th><i class="fas fa-arrow-up"></i> Peak Power (W)</th>
                                <th><i class="fas fa-wave-square"></i> Avg Current (A)</th>
                                <th><i class="fas fa-plug"></i> Avg Voltage (V)</th>
                                <th><i class="fas fa-battery-three-quarters"></i> Energy (kWh)</th>
                                <th><i class="fas fa-chart-bar"></i> Readings</th>
                            </tr>
                        </thead>
                        <tbody id="detailsTableBody">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        let powerChart, currentChart, voltageChart, energyChart;
        let historicalData = [];

        // Set default dates (last 7 days)
        document.getElementById('endDate').valueAsDate = new Date();
        let startDate = new Date();
        startDate.setDate(startDate.getDate() - 7);
        document.getElementById('startDate').valueAsDate = startDate;

        document.getElementById('loadDataBtn').addEventListener('click', loadHistoricalData);

        async function loadHistoricalData() {
            const start = document.getElementById('startDate').value;
            const end = document.getElementById('endDate').value;
            const metric = document.getElementById('metricSelect').value;

            if (!start || !end) {
                alert('Please select both start and end dates');
                return;
            }

            document.getElementById('loadingSpinner').style.display = 'block';
            document.getElementById('statsContainer').style.display = 'none';

            try {
                const response = await fetch(`/HistoricalStats/GetHistoricalData?startDate=${start}&endDate=${end}&metric=${metric}`);
                const result = await response.json();

                if (result.success) {
                    historicalData = result.data;
                    displayStats(result.data);
                    updateDateRangeInfo(start, end);
                } else {
                    alert('Error: ' + result.message);
                    document.getElementById('loadingSpinner').style.display = 'none';
                }
            } catch (error) {
                alert('Failed to load data: ' + error.message);
                document.getElementById('loadingSpinner').style.display = 'none';
            }
        }

        function updateDateRangeInfo(start, end) {
            document.getElementById('dateRangeInfo').style.display = 'block';
            document.getElementById('dateRangeText').textContent = `${start} to ${end}`;
        }

        function displayStats(data) {
            if (!data || data.length === 0) {
                alert('No data available for selected date range');
                document.getElementById('loadingSpinner').style.display = 'none';
                return;
            }

            // Calculate summary statistics
            const totalPower = data.reduce((sum, d) => sum + d.averagePower, 0);
            const avgPower = totalPower / data.length;
            const totalEnergy = data.reduce((sum, d) => sum + d.energyConsumed, 0);
            const avgCurrent = data.reduce((sum, d) => sum + d.averageCurrent, 0) / data.length;
            const avgVoltage = data.reduce((sum, d) => sum + d.averageVoltage, 0) / data.length;
            const peakPower = Math.max(...data.map(d => d.maxPower));

            // Display summary cards
            const summaryHTML = `
                <div class="col-md-3 col-sm-6">
                    <div class="metric-card">
                        <div class="metric-icon"><i class="fas fa-bolt"></i></div>
                        <div class="metric-label">Average Power</div>
                        <div class="metric-value">${avgPower.toFixed(2)}</div>
                        <div class="metric-unit">Watts</div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="metric-card">
                        <div class="metric-icon"><i class="fas fa-wave-square"></i></div>
                        <div class="metric-label">Average Current</div>
                        <div class="metric-value">${avgCurrent.toFixed(3)}</div>
                        <div class="metric-unit">Amperes</div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="metric-card">
                        <div class="metric-icon"><i class="fas fa-plug"></i></div>
                        <div class="metric-label">Average Voltage</div>
                        <div class="metric-value">${avgVoltage.toFixed(1)}</div>
                        <div class="metric-unit">Volts</div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="metric-card">
                        <div class="metric-icon"><i class="fas fa-battery-three-quarters"></i></div>
                        <div class="metric-label">Total Energy</div>
                        <div class="metric-value">${totalEnergy.toFixed(3)}</div>
                        <div class="metric-unit">kWh</div>
                    </div>
                </div>
            `;
            document.getElementById('summaryCards').innerHTML = summaryHTML;

            // Display charts
            createCharts(data);

            // Display table
            displayTable(data);

            document.getElementById('loadingSpinner').style.display = 'none';
            document.getElementById('statsContainer').style.display = 'block';
        }

        function createCharts(data) {
            const labels = data.map(d => d.displayDate);
            const powerData = data.map(d => d.averagePower);
            const currentData = data.map(d => d.averageCurrent);
            const voltageData = data.map(d => d.averageVoltage);
            const energyData = data.map(d => d.energyConsumed);

            // Destroy existing charts
            if (powerChart) powerChart.destroy();
            if (currentChart) currentChart.destroy();
            if (voltageChart) voltageChart.destroy();
            if (energyChart) energyChart.destroy();

            // Power Chart
            const powerCtx = document.getElementById('powerCanvas').getContext('2d');
            powerChart = new Chart(powerCtx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Average Power (W)',
                        data: powerData,
                        backgroundColor: 'rgba(0, 255, 255, 0.6)',
                        borderColor: 'rgba(0, 255, 255, 1)',
                        borderWidth: 2,
                        borderRadius: 8
                    }]
                },
                options: getChartOptions('Average Power (Watts)')
            });

            // Current Chart
            const currentCtx = document.getElementById('currentCanvas').getContext('2d');
            currentChart = new Chart(currentCtx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Average Current (A)',
                        data: currentData,
                        backgroundColor: 'rgba(138, 43, 226, 0.6)',
                        borderColor: 'rgba(138, 43, 226, 1)',
                        borderWidth: 2,
                        borderRadius: 8
                    }]
                },
                options: getChartOptions('Average Current (Amperes)')
            });

            // Voltage Chart
            const voltageCtx = document.getElementById('voltageCanvas').getContext('2d');
            voltageChart = new Chart(voltageCtx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Average Voltage (V)',
                        data: voltageData,
                        backgroundColor: 'rgba(255, 0, 255, 0.2)',
                        borderColor: 'rgba(255, 0, 255, 1)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 5,
                        pointHoverRadius: 7,
                        pointBackgroundColor: 'rgba(255, 0, 255, 1)',
                        pointBorderColor: '#fff'
                    }]
                },
                options: getChartOptions('Average Voltage (Volts)')
            });

            // Energy Chart
            const energyCtx = document.getElementById('energyCanvas').getContext('2d');
            energyChart = new Chart(energyCtx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Energy Consumed (kWh)',
                        data: energyData,
                        backgroundColor: 'rgba(0, 255, 128, 0.6)',
                        borderColor: 'rgba(0, 255, 128, 1)',
                        borderWidth: 2,
                        borderRadius: 8
                    }]
                },
                options: getChartOptions('Energy Consumed (kWh)')
            });
        }

        function getChartOptions(title) {
            return {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top',
                        labels: {
                            font: { size: 14, weight: 'bold' },
                            padding: 15,
                            color: '#e0e0e0'
                        }
                    },
                    title: {
                        display: true,
                        text: title,
                        font: { size: 16, weight: 'bold' },
                        padding: 15,
                        color: '#00d4d4'
                    },
                    tooltip: {
                        backgroundColor: 'rgba(0, 0, 0, 0.9)',
                        padding: 12,
                        titleFont: { size: 14 },
                        bodyFont: { size: 13 },
                        cornerRadius: 8,
                        borderColor: 'rgba(0, 255, 255, 0.5)',
                        borderWidth: 1
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { 
                            color: 'rgba(0, 255, 255, 0.1)',
                            drawBorder: false
                        },
                        ticks: { 
                            font: { size: 12 },
                            color: '#b0b0b0'
                        }
                    },
                    x: {
                        grid: { 
                            display: false 
                        },
                        ticks: { 
                            font: { size: 12 },
                            color: '#b0b0b0'
                        }
                    }
                }
            };
        }

        function displayTable(data) {
            const tbody = document.getElementById('detailsTableBody');
            tbody.innerHTML = data.map(d => `
                <tr>
                    <td><strong>${d.displayDate}</strong><br><small style="color: #0e0e0fff;">${d.date}</small></td>
                    <td><span class="badge bg-info">${d.averagePower.toFixed(2)}</span></td>
                    <td><span class="badge bg-danger">${d.maxPower.toFixed(2)}</span></td>
                    <td><strong style="color: #131414ff;">${d.averageCurrent.toFixed(4)}</strong></td>
                    <td><strong style="color: #131414ff;">${d.averageVoltage.toFixed(1)}</strong></td>
                    <td><strong style="color:#131414ff;">${d.energyConsumed.toFixed(3)}</strong></td>
                    <td><span class="badge bg-primary">${d.readingCount}</span></td>
                </tr>
            `).join('');
        }

        // Load default data on page load
        window.addEventListener('load', () => {
            loadHistoricalData();
        });
    </script>
</body>
</html>