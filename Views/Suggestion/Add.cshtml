@model SmartEnergy.Web.Models.Suggestion

@{
    ViewData["Title"] = "Add Suggestion";
}

<h2 class="text-center my-4">Add a New Suggestion</h2>

<div class="row justify-content-center">
    <div class="col-md-6">
        <form asp-action="Add" method="post">
            <div class="form-group mb-3">
                <label asp-for="Text" class="form-label">Suggestion Text</label>
                <textarea asp-for="Text" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Text" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Source" class="form-label">Source (AI / Static)</label>
                <input asp-for="Source" class="form-control" />
                <span asp-validation-for="Source" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Rating" class="form-label">Rating (Optional)</label>
                <input asp-for="Rating" class="form-control" type="number" min="1" max="5" />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">Submit Suggestion</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}